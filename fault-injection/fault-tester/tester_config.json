{
  "scheduler": {
    "fast_interval_sec": 2,
    "telemetry_interval_sec": 20
  },
  "targets": {
    "ping_target": "8.8.8.8",
    "dns_targets": [
      {
        "name": "google.com",
        "scope": "external"
      }
    ],
    "http_targets": [
      {
        "url": "http://192.168.12.1:8080/testfile_1mb.bin",
        "scope": "local"
      }
    ],
    "dns_resolver": "8.8.8.8",
    "iface": "wlan0"
  },
  "thresholds": {
    "dns_latency_threshold_ms": 243,
    "loss_threshold_pct": 20,
    "rtt_threshold_ms": 279,
    "recovery_rtt_threshold_ms": 224,
    "http_total_threshold_ms": 1535,
    "recovery_http_total_threshold_ms": 1228,
    "http_ttfb_threshold_ms": 88,
    "recovery_http_ttfb_threshold_ms": 71
  },
  "dynamic_thresholds": {
    "enabled": true,
    "events": {
      "S1_DNS_DEGRADED": {
        "dns_latency_ms": {
          "method": "ewma",
          "warmup_samples": 60,
          "alpha": 0.1,
          "beta": 0.1,
          "k": 3
        }
      },
      "S4_HIGH_RTT": {
        "rtt_ms": {
          "method": "ewma",
          "warmup_samples": 12,
          "alpha": 0.1,
          "beta": 0.1,
          "k": 3
        }
      },
      "S5_HTTP_SLOW": {
        "http_total_ms": {
          "method": "ewma",
          "warmup_samples": 12,
          "alpha": 0.1,
          "beta": 0.1,
          "k": 3
        },
        "http_ttfb_ms": {
          "method": "ewma",
          "warmup_samples": 12,
          "alpha": 0.1,
          "beta": 0.1,
          "k": 3
        }
      }
    }
  },
  "rules": {
    "S1_DNS_DEGRADED": {
      "confirm_consecutive": 2
    },
    "S2_DNS_TIMEOUT_BURST": {
      "n_dns": 10,
      "m_dns": 3
    },
    "S3_LOSS_BURST": {
      "n_ping": 20,
      "m_ping": 4
    },
    "S4_HIGH_RTT": {
      "confirm_consecutive": 2
    },
    "S5_HTTP_SLOW": {
      "confirm_consecutive": 2
    },
    "S6_CONNECTIVITY_FLAP": {
      "n_flap": 15,
      "m_transition": 4
    }
  }
}
