{
  "device": {
    "device_id": "uno-q-01",
    "site_name": "ITS",
    "timezone": "Asia/Jakarta",
    "iface": "wlan0"
  },
  "scheduler": {
    "telemetry_interval_sec": 30,
    "throughput_interval_sec": 300,
    "loop_sleep_sec": 1,
    "throughput_stagger_sec": 10
  },
  "modules": {
    "wifi": true,
    "network": true,
    "ping": true,
    "dns": true,
    "http": true,
    "throughput": true
  },
  "output": {
    "output_dir": "./out",
    "format": "jsonl",
    "print_pretty": false
  },
  "ping": {
    "target": "8.8.8.8",
    "count": 5,
    "interval_sec": 0.2,
    "timeout_sec": 10
  },
  "dns": {
    "resolvers": [
      "system"
    ],
    "domains_routine": [
      "its.ac.id",
      "google.com",
      "youtube.com"
    ],
    "timeout_sec": 5
  },
  "http": {
    "targets": [
      "https://example.com"
    ],
    "connect_timeout_sec": 5,
    "max_time_sec": 15
  },
  "throughput": {
    "mode": "routine",
    "connect_timeout_sec": 5,
    "routine": {
      "url": "https://proof.ovh.net/files/1Mb.dat",
      "expected_bytes": 1048576,
      "runs": 2,
      "warmup": 0,
      "pause_sec": 1,
      "max_time_sec": 20
    },
    "stress": {
      "url": "https://proof.ovh.net/files/10Mb.dat",
      "expected_bytes": 10485760,
      "runs": 1,
      "warmup": 0,
      "pause_sec": 1,
      "max_time_sec": 90
    }
  }
}