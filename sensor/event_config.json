{
  "_comment": "Threshold configuration for Micro-UXI event detector (event_detector.py).",

  "detector": {
    "startup_grace_sec":      10,
    "heartbeat_interval_sec": 30,
    "print_normal":           false,
    "output_jsonl":           null
  },

  "events": {

    "S1_RTT_INCREASE": {
      "enabled":      true,
      "description":  "Sustained high round-trip latency on the upstream path.",
      "probe":        "telemetry",
      "conditions": {
        "rtt_avg_ms_gt":   150.0,
        "loss_pct_lt":     10.0
      },
      "confirm_consecutive": 2
    },

    "S2_DNS_OUTAGE_BURST": {
      "enabled":      true,
      "description":  "All DNS domains fail simultaneously while ping is OK (local DNS drop).",
      "probe":        "fast",
      "conditions": {
        "all_dns_fail":      true,
        "ping_ok":           true,
        "wifi_up":           true,
        "dns_latency_ms_lt": 500
      },
      "confirm_consecutive": 2
    },

    "S3_PACKET_LOSS_BURST": {
      "enabled":          true,
      "description":      "Ping fails while DNS may still resolve (packet loss on path).",
      "probe":            "fast",
      "suppressed_by":    ["S6_CONNECTIVITY_FLAP"],
      "conditions": {
        "ping_fail": true,
        "wifi_up":   true
      },
      "confirm_consecutive": 2
    },

    "S4_DNS_DELAY": {
      "enabled":      true,
      "description":  "DNS queries succeed but abnormally slowly (DNS delay injected).",
      "probe":        "fast",
      "conditions": {
        "any_dns_slow_ms_gte": 300,
        "all_dns_fail":        false,
        "ping_ok":             true,
        "wifi_up":             true
      },
      "confirm_consecutive": 2
    },

    "S5_THROTTLE": {
      "enabled":      true,
      "description":  "Bandwidth severely limited, detected via throughput probe.",
      "probe":        "throughput",
      "conditions": {
        "throughput_avg_mbps_lt": 3.0,
        "http_success_rate_lt":   1.0
      },
      "confirm_consecutive": 1
    },

    "S6_CONNECTIVITY_FLAP": {
      "enabled":      true,
      "description":  "Upstream interface down: ping + DNS both fail, wifi stays associated.",
      "probe":        "fast",
      "conditions": {
        "ping_fail":   true,
        "all_dns_fail":true,
        "wifi_up":     true
      },
      "confirm_consecutive": 2
    }
  }
}
