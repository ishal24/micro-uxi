{
  "device": {
    "device_id": "uno-q-01",
    "site_name": "ITS",
    "timezone": "Asia/Jakarta",
    "iface": "wlan0"
  },
  "scheduler": {
    "fast_interval_sec": 2,
    "telemetry_interval_sec": 20,
    "throughput_interval_sec": 30
  },
  "fast_probe": {
    "enabled": true,
    "ping_target": "8.8.8.8",
    "ping_timeout_sec": 1,
    "dns_timeout_sec": 2.0,
    "dns_resolver": "8.8.8.8",
    "targets": [
      {
        "name": "google.com",
        "scope": "external"
      }
    ]
  },
  "telemetry_probe": {
    "enabled": true,
    "ping_target": "8.8.8.8",
    "ping_count": 5,
    "ping_interval_sec": 0.2,
    "ping_timeout_sec": 3,
    "dns_timeout_sec": 5,
    "dns_resolvers": [
      "8.8.8.8"
    ],
    "dns_targets": [
      {
        "name": "google.com",
        "scope": "external"
      }
    ],
    "http_targets": [
      {
        "url": "http://192.168.12.1:8080/testfile_1mb.bin",
        "scope": "local",
        "expected_status_min": 200,
        "expected_status_max": 399
      }
    ],
    "http_connect_timeout_sec": 5,
    "http_max_time_sec": 15
  },

  "throughput_probe": {
    "enabled": true,
    "mode": "routine",
    "connect_timeout_sec": 5,
    "routine": {
      "download": {
        "enabled": true,
        "url": "https://speed.cloudflare.com/__down?bytes=10000000",
        "expected_bytes": 10000000,
        "runs": 3,
        "warmup": 1,
        "pause_sec": 2,
        "max_time_sec": 60
      },
      "upload": {
        "enabled": true,
        "url": "https://speed.cloudflare.com/__up",
        "expected_bytes": 5000000,
        "payload_path": "./monitoring/out/payloads/upload_5mb.bin",
        "payload_source": "zero",
        "runs": 3,
        "warmup": 1,
        "pause_sec": 2,
        "max_time_sec": 60
      }
    },
    "stress": {
      "download": {
        "enabled": true,
        "url": "https://speed.cloudflare.com/__down?bytes=25000000",
        "expected_bytes": 25000000,
        "runs": 3,
        "warmup": 1,
        "pause_sec": 2,
        "max_time_sec": 120
      },
      "upload": {
        "enabled": true,
        "url": "https://speed.cloudflare.com/__up",
        "expected_bytes": 10000000,
        "payload_path": "./monitoring/out/payloads/upload_10mb.bin",
        "payload_source": "zero",
        "runs": 3,
        "warmup": 1,
        "pause_sec": 2,
        "max_time_sec": 120
      }
    }
  },
  "overhead_probe": {
    "enabled": false,
    "refresh_process_every_samples": 30,
    "process_names": [
      "monitoring.controller",
      "controller.py",
      "telemetry_probe.py",
      "fast_probe.py",
      "throughput_probe.py"
    ]
  },
  "detector": {
    "detection_mode": "static",
    "events": {
      "DNS_DEGRADED": {
        "confirm_consecutive": 99999
      },
      "DNS_TIMEOUT_BURST": {
        "confirm_consecutive": 99999
      },
      "LOSS_BURST": {
        "confirm_consecutive": 99999
      },
      "HIGH_RTT": {
        "confirm_consecutive": 99999
      },
      "HTTP_SLOW": {
        "confirm_consecutive": 99999
      },
      "CONNECTIVITY_FLAP": {
        "confirm_consecutive": 99999
      },
      "BANDWIDTH_THROTTLE": {
        "confirm_consecutive": 99999
      }
    }
  },
  "thresholds": {
    "dns_latency_threshold_ms": 99999,
    "dns_fail_ratio_threshold": 1.1,
    "dns_recovery_success_ratio": 1.0,
    "loss_threshold_pct": 101,
    "recovery_loss_threshold_pct": 5,
    "loss_window_sec": 40,
    "rtt_threshold_ms": 99999,
    "recovery_rtt_threshold_ms": 99999,
    "rtt_loss_upper_bound_pct": 101,
    "http_total_threshold_ms": 99999,
    "recovery_http_total_threshold_ms": 99999,
    "http_ttfb_threshold_ms": 99999,
    "recovery_http_ttfb_threshold_ms": 99999,
    "throughput_download_threshold_mbps": 0,
    "throughput_upload_threshold_mbps": 0,
    "flap_transition_threshold": 99999,
    "flap_window_sec": 30,
    "http_expected_status_min": 200,
    "http_expected_status_max": 399
  },
  "output": {
    "enabled": true,
    "output_dir": "./monitoring/out/preliminary_test_run",
    "sample_format": "jsonl",
    "print_pretty": false,
    "print_fast_normal": false
  }
}
