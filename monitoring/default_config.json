{
  "device": {
    "device_id": "uno-q-01",
    "site_name": "ITS",
    "timezone": "Asia/Jakarta",
    "iface": "wlan0"
  },
  "scheduler": {
    "fast_interval_sec": 5,
    "telemetry_interval_sec": 30,
    "throughput_interval_sec": 300,
    "overhead_interval_sec": 30
  },
  "fast_probe": {
    "enabled": true,
    "ping_target": "8.8.8.8",
    "ping_timeout_sec": 1,
    "dns_timeout_sec": 2.0,
    "dns_resolver": "8.8.8.8",
    "targets": [
      {
        "name": "its.ac.id",
        "scope": "internal"
      },
      {
        "name": "google.com",
        "scope": "external"
      }
    ]
  },
  "telemetry_probe": {
    "enabled": true,
    "ping_target": "8.8.8.8",
    "ping_count": 5,
    "ping_interval_sec": 0.2,
    "ping_timeout_sec": 10,
    "dns_timeout_sec": 5,
    "dns_resolvers": [
      "system"
    ],
    "dns_targets": [
      {
        "name": "its.ac.id",
        "scope": "internal"
      },
      {
        "name": "google.com",
        "scope": "external"
      },
      {
        "name": "youtube.com",
        "scope": "external"
      }
    ],
    "http_targets": [
      {
        "url": "https://www.its.ac.id",
        "scope": "internal",
        "expected_status_min": 200,
        "expected_status_max": 399
      }
    ],
    "http_connect_timeout_sec": 5,
    "http_max_time_sec": 15
  },
  "throughput_probe": {
    "enabled": true,
    "mode": "routine",
    "connect_timeout_sec": 5,
    "routine": {
      "download": {
        "enabled": true,
        "url": "https://speed.cloudflare.com/__down?bytes=10000000",
        "expected_bytes": 10000000,
        "runs": 3,
        "warmup": 1,
        "pause_sec": 2,
        "max_time_sec": 60
      },
      "upload": {
        "enabled": true,
        "url": "https://speed.cloudflare.com/__up",
        "expected_bytes": 5000000,
        "payload_path": "./monitoring/out/payloads/upload_5mb.bin",
        "payload_source": "zero",
        "runs": 3,
        "warmup": 1,
        "pause_sec": 2,
        "max_time_sec": 60
      }
    },
    "stress": {
      "download": {
        "enabled": true,
        "url": "https://speed.cloudflare.com/__down?bytes=25000000",
        "expected_bytes": 25000000,
        "runs": 3,
        "warmup": 1,
        "pause_sec": 2,
        "max_time_sec": 120
      },
      "upload": {
        "enabled": true,
        "url": "https://speed.cloudflare.com/__up",
        "expected_bytes": 10000000,
        "payload_path": "./monitoring/out/payloads/upload_10mb.bin",
        "payload_source": "zero",
        "runs": 3,
        "warmup": 1,
        "pause_sec": 2,
        "max_time_sec": 120
      }
    }
  },
  "overhead_probe": {
    "enabled": true,
    "refresh_process_every_samples": 30,
    "process_names": [
      "monitoring.controller",
      "controller.py",
      "telemetry_probe.py",
      "fast_probe.py",
      "throughput_probe.py"
    ]
  },
  "detector": {
    "detection_mode": "static",
    "startup_grace_sec": 10,
    "merge_gap_sec": 10,
    "recovery_hold_sec": 10,
    "baseline": {
      "dns_window_samples": 30,
      "rtt_window_samples": 20,
      "http_window_samples": 20,
      "throughput_window_samples": 8,
      "minimum_samples": 5,
      "mad_k": 3.0,
      "recovery_mad_k": 1.5
    },
    "events": {
      "DNS_DEGRADED": {
        "confirm_consecutive": 2,
        "recovery_consecutive": 2,
        "minimum_success_ratio": 1.0
      },
      "DNS_TIMEOUT_BURST": {
        "confirm_consecutive": 2,
        "recovery_consecutive": 2,
        "recovery_success_ratio": 1.0
      },
      "LOSS_BURST": {
        "confirm_consecutive": 1,
        "recovery_consecutive": 2,
        "minimum_samples": 5
      },
      "HIGH_RTT": {
        "confirm_consecutive": 2,
        "recovery_consecutive": 2
      },
      "HTTP_SLOW": {
        "confirm_consecutive": 2,
        "recovery_consecutive": 2
      },
      "CONNECTIVITY_FLAP": {
        "confirm_consecutive": 1,
        "recovery_consecutive": 1
      },
      "BANDWIDTH_THROTTLE": {
        "confirm_consecutive": 1,
        "recovery_consecutive": 1
      }
    }
  },
  "thresholds": {
    "dns_latency_threshold_ms": 300,
    "dns_fail_ratio_threshold": 1.0,
    "dns_recovery_success_ratio": 1.0,
    "loss_threshold_pct": 20,
    "recovery_loss_threshold_pct": 5,
    "loss_window_sec": 10,
    "rtt_threshold_ms": 150,
    "recovery_rtt_threshold_ms": 120,
    "rtt_loss_upper_bound_pct": 10,
    "http_total_threshold_ms": 2000,
    "recovery_http_total_threshold_ms": 1500,
    "http_ttfb_threshold_ms": 1000,
    "recovery_http_ttfb_threshold_ms": 800,
    "throughput_download_threshold_mbps": 3,
    "throughput_upload_threshold_mbps": 3,
    "flap_transition_threshold": 2,
    "flap_window_sec": 30,
    "http_expected_status_min": 200,
    "http_expected_status_max": 399
  },
  "output": {
    "enabled": false,
    "output_dir": "./monitoring/out",
    "sample_format": "jsonl",
    "print_pretty": false,
    "print_fast_normal": false
  },
  "stream": {
    "enabled": false,
    "host": "10.4.78.103",
    "port": "5000",
    "scheme": "http",
    "sensor_endpoint": "/api/ingest/sensor",
    "overhead_endpoint": "/api/ingest/overhead",
    "include_sensor": true,
    "include_overhead": true,
    "api_key": "",
    "timeout_sec": 5,
    "max_queue": 100
  },
  "remote_control": {
    "enabled": true,
    "endpoint": "/api/config",
    "poll_interval_sec": 30,
    "timeout_sec": 5
  },
  "evidence": {
    "enabled": true,
    "pre_window_sec": 30,
    "post_window_sec": 30,
    "alignment_delta_sec": 5
  }
}