{
  "device": {
    "device_id": "uno-q-01",
    "site_name": "ITS",
    "timezone": "Asia/Jakarta",
    "iface": "wlan0"
  },
  "controller": {
    "modules": {
      "monitoring": true,
      "detection": false,
      "overhead": false,
      "exporter": false
    }
  },
  "scheduler": {
    "fast_interval_sec": 2,
    "telemetry_interval_sec": 20
  },
  "targets": {
    "ping_target": "8.8.8.8",
    "ping_timeout_sec": 1,
    "dns_resolver": "8.8.8.8",
    "dns_timeout_sec": 2,
    "dns_resolvers": [
      "system"
    ],
    "telemetry_dns_timeout_sec": 5,
    "telemetry_ping_count": 5,
    "telemetry_ping_interval_sec": 0.2,
    "telemetry_ping_timeout_sec": 10,
    "http_connect_timeout_sec": 5,
    "http_max_time_sec": 15,
    "dns_targets": [
      {
        "name": "google.com",
        "scope": "external"
      }
    ],
    "http_targets": [
      {
        "url": "http://192.168.12.1:8080/testfile_1mb.bin",
        "scope": "local",
        "expected_status_min": 200,
        "expected_status_max": 399
      }
    ]
  },
  "monitoring": {
    "output_dir": "./out",
    "write_jsonl": false,
    "verbose": true
  }
}
